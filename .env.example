# === 语音服务（豆包/火山引擎）===
VOICE_PROVIDER=doubao
DOUBAO_TTS_API_KEY=your-api-key
DOUBAO_TTS_DEFAULT_VOICE_TYPE=zh_female_vv_uranus_bigtts

# === TTS 资源 ===
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_CLONE_RESOURCE_ID=seed-icl-2.0

# === TTS 参数（可选）===
DOUBAO_TTS_ENCODING=mp3
DOUBAO_TTS_SAMPLE_RATE=24000

# === DeepSeek LLM ===
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === 云端 PostgreSQL ===
DATABASE_URL=postgresql://admin:your-db-password@127.0.0.1:5432/companion
JWT_SECRET=replace-with-a-long-random-string
